# Ejercicio 4: División de dos números enteros con manejo de errores
try:
    # Solicitar al usuario los dos números enteros
    num1 = int(input("Ingrese el primer número entero: "))
    num2 = int(input("Ingrese el segundo número entero: "))

    # Realizar la división
    resultado = num1 / num2

    # Mostrar el resultado
    print(f"El resultado de {num1} / {num2} es: {resultado}")

# Captura si el usuario ingresa algo que no es un número entero
except ValueError:
    print("Error: Debe ingresar números enteros")

# Captura si el usuario intenta dividir entre cero
except ZeroDivisionError:
    print("Error: No se puede dividir entre cero")
