# Ejercicio 5: Sistema de gestión de estudiantes
estudiantes = []  # Lista donde se guardarán los estudiantes como diccionarios

# Ciclo para ingresar estudiantes hasta que el usuario escriba 'fin'
while True:
    nombre = input("Ingrese el nombre del estudiante (o 'fin' para terminar): ").strip()
    
    if nombre.lower() == "fin":  # Condición para salir del ciclo
        break
    
    try:
        # Solicitar la nota y convertirla a número decimal
        nota = float(input(f"Ingrese la nota de {nombre} (0 a 5.0): "))
        
        # Validar que la nota esté dentro del rango permitido
        if nota < 0 or nota > 5.0:
            print("Error: La nota debe estar entre 0 y 5.0")
            continue  # Volver al inicio del ciclo para ingresar otro estudiante
        
        # Guardar el estudiante como diccionario en la lista
        estudiantes.append({"nombre": nombre, "nota": nota})
    
    # Captura si la nota ingresada no es un número
    except ValueError:
        print("Error: Debe ingresar un número válido para la nota")


# Función para calcular el promedio de notas
def promedio_notas(estudiantes):
    if len(estudiantes) == 0:
        return 0
    total = sum(est["nota"] for est in estudiantes)
    return total / len(estudiantes)


# Función para obtener el mejor estudiante
def mejor_estudiante(estudiantes):
    if len(estudiantes) == 0:
        return None, None
    mejor = max(estudiantes, key=lambda x: x["nota"])
    return mejor["nombre"], mejor["nota"]


# Función para obtener el peor estudiante
def peor_estudiante(estudiantes):
    if len(estudiantes) == 0:
        return None, None
    peor = min(estudiantes, key=lambda x: x["nota"])
    return peor["nombre"], peor["nota"]


# --- Generación del reporte final ---
print("\n--- Reporte Final ---")
print(f"Número de estudiantes: {len(estudiantes)}")
print(f"Promedio de notas: {promedio_notas(estudiantes):.2f}")

# Mejor y peor estudiante
nombre_mejor, nota_mejor = mejor_estudiante(estudiantes)
nombre_peor, nota_peor = peor_estudiante(estudiantes)
if nombre_mejor:
    print(f"Mejor estudiante: {nombre_mejor} con nota {nota_mejor}")
if nombre_peor:
    print(f"Peor estudiante: {nombre_peor} con nota {nota_peor}")

# --- Bonus: ordenar estudiantes de menor a mayor nota ---
estudiantes_ordenados = sorted(estudiantes, key=lambda x: x["nota"])
print("\nEstudiantes ordenados por nota (menor a mayor):")
for est in estudiantes_ordenados:
    print(f"{est['nombre']}: {est['nota']}")
